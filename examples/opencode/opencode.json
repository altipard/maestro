{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "maestro": {
      "api": "openai",
      "name": "Maestro",
      "id": "maestro",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "apiKey": "local"
      },
      "models": {
        "qwen3.5:latest": {
          "id": "qwen3.5:latest",
          "name": "Qwen 3.5 (Ollama local)",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "anthropic/claude-sonnet-4": {
          "id": "anthropic/claude-sonnet-4",
          "name": "Claude Sonnet 4 (OpenRouter)",
          "tool_call": true,
