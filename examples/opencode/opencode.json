        },
        "nvidia/nemotron-3-super-120b-a12b:free": {
          "id": "nvidia/nemotron-3-super-120b-a12b:free",
          "name": "Nemotron 3 Super 120B (OpenRouter, free)",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
