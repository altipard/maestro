# ── LibreChat Settings ──────────────────────────────────────────────
# Required for LibreChat to function
CREDS_KEY=your-random-32-char-string-here
CREDS_IV=your-random-16-char-string
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# ── LLM Provider Keys (uncomment as needed) ───────────────────────
# Only needed if you enable these providers in the maestro config

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# GOOGLE_API_KEY=AI...

# ── RAG Settings ───────────────────────────────────────────────────
RAG_PORT=8000
EMBEDDINGS_PROVIDER=openai
